# ── mzpeak-example-data: describe, don't store ───────────────────────────────
# This repo commits ONLY descriptions, manifests and scripts. Every heavy data
# artifact is reconstructed by scripts/update.sh and must never be committed.

# Raw vendor acquisitions (files AND directories)
*.raw
*.RAW
*.d/
*.wiff
*.wiff.scan
*.wiff2
*.lcd
*.baf
analysis.baf*
*.tdf
*.tdf_bin
*.tsf
*.tsf_bin

# Open formats + converted output
*.mzML
*.mzML.gz
*.mzml
*.imzML
*.imzml
*.ibd
*.mzpeak

# Optical / imaging side files
*.tif
*.tiff
*.svs

# Bulk archives + build/work dirs
*.zip
*.gz
*.tar
.build/
out/
target/
node_modules/

# Cruft
.DS_Store
*.log
*.tmp
*.swp

# Tracked files (README.md, results.tsv, manifests, cors.json, scripts/**) match none of the
# patterns above, so they are committed without needing a negation. Note: a file placed INSIDE an
# ignored unit dir (e.g. a `*.d/`) cannot be un-ignored — git won't descend into an ignored dir —
# so never put tracked files under a data-unit path.

# Inside each dataset folder (data/<tile>/<dataset>/), commit ONLY its <id>.json
# description -- never the downloaded/converted data (any format, incl .tsv/.csv).
data/*/*/*
!data/*/*/*.json
!data/*/*/*.yaml
!data/*/*/*.yml

# Python bytecode
__pycache__/
*.pyc
